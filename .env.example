# Database
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/mehfil_db"

# Redis (Upstash)
REDIS_URL="rediss://default:PASSWORD@HOST:PORT"

# JWT
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"
JWT_EXPIRES_IN="1h"
JWT_REFRESH_SECRET="different-super-secret-refresh-key-min-32-chars"
JWT_REFRESH_EXPIRES_IN="30d"

# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-your-secret"

# LiveKit (shared server at 187.124.213.14)
# Room names are prefixed "mehfil_room_" to stay isolated from other apps (e.g. Bazmi)
LIVEKIT_URL="wss://187.124.213.14"
LIVEKIT_API_KEY="your-livekit-api-key"
LIVEKIT_API_SECRET="your-livekit-api-secret"

# Server
PORT=3000
NODE_ENV=development
CLIENT_URL="http://localhost:3001"
