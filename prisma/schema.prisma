generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  googleId  String   @unique @map("google_id") @db.VarChar(255)
  name      String   @db.VarChar(100)
  /// Unique public handle, e.g. "soban". Null until the user picks one.
  username  String?  @unique @db.VarChar(30)
  bio       String?  @db.VarChar(160)
  email     String   @unique @db.VarChar(255)
  avatar    String?  @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at")

  hostedRooms Room[]       @relation("RoomHost")
  messages    Message[]
  roomMembers RoomMember[]
  roomBans    RoomBan[]

  @@map("users")
}

model Room {
  id           Int      @id @default(autoincrement())
  name         String   @db.VarChar(150)
  hostId       Int      @map("host_id")
  creatorId    Int      @map("creator_id")
  isPublic     Boolean  @default(true) @map("is_public")
  youtubeId    String?  @map("youtube_id") @db.VarChar(50)
  nextYoutubeId String?  @map("next_youtube_id") @db.VarChar(50)
  timestampSec Float    @default(0) @map("timestamp_sec")
  isPlaying    Boolean  @default(false) @map("is_playing")
  isLive       Boolean  @default(true) @map("is_live")
  createdAt    DateTime @default(now()) @map("created_at")

  host     User         @relation("RoomHost", fields: [hostId], references: [id])
  messages Message[]
  members  RoomMember[]
  bans     RoomBan[]

  @@map("rooms")
}

/// A user the host removed from a room. Bans are permanent: the room is hidden
/// from browse and room:join is refused.
model RoomBan {
  roomId   Int      @map("room_id")
  userId   Int      @map("user_id")
  bannedAt DateTime @default(now()) @map("banned_at")

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@id([roomId, userId])
  @@map("room_bans")
}

model Message {
  id        Int      @id @default(autoincrement())
  roomId    Int      @map("room_id")
  userId    Int      @map("user_id")
  text      String   @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at")

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@map("messages")
}

model RoomMember {
  roomId   Int      @map("room_id")
  userId   Int      @map("user_id")
  /// The user muted their own mic.
  isMuted  Boolean  @default(true) @map("is_muted")
  /// The host muted them. Only the host can clear this — the user cannot
  /// unmute themselves out of it.
  mutedByHost Boolean @default(false) @map("muted_by_host")
  joinedAt DateTime @default(now()) @map("joined_at")

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@id([roomId, userId])
  @@map("room_members")
}
